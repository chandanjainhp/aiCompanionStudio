# ════════════════════════════════════════════════════════════════
# OpenRouter.ai Integration - Environment Configuration
# ════════════════════════════════════════════════════════════════

# 🔑 REQUIRED: OpenRouter.ai API Key
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-your-api-key-here

# 🌐 OpenRouter API Base URL (usually doesn't need changing)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# 📍 Your Application URL (used as HTTP-Referer header for OpenRouter)
# Development
APP_URL=http://localhost:5173

# Production (uncomment and update for production)
# APP_URL=https://yourdomain.com

# ════════════════════════════════════════════════════════════════
# Server Configuration
# ════════════════════════════════════════════════════════════════

NODE_ENV=development
PORT=3000

# ════════════════════════════════════════════════════════════════
# Database
# ════════════════════════════════════════════════════════════════

DATABASE_URL=postgresql://user:password@localhost:5432/aicompanion

# ════════════════════════════════════════════════════════════════
# JWT Authentication
# ════════════════════════════════════════════════════════════════

JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ════════════════════════════════════════════════════════════════
# File Upload & Storage
# ════════════════════════════════════════════════════════════════

FILE_UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# Cloudinary (for avatar uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ════════════════════════════════════════════════════════════════
# Email Configuration
# ════════════════════════════════════════════════════════════════

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM_NAME=ChatForge
EMAIL_FROM_EMAIL=noreply@chatforge.com

# ════════════════════════════════════════════════════════════════
# CORS Configuration
# ════════════════════════════════════════════════════════════════

CORS_ORIGIN=http://localhost:5173

# ════════════════════════════════════════════════════════════════
# Logging
# ════════════════════════════════════════════════════════════════

LOG_LEVEL=debug

# ════════════════════════════════════════════════════════════════
# DEPRECATED: Google Generative AI (no longer used)
# ════════════════════════════════════════════════════════════════
# GOOGLE_API_KEY=xxx

# ════════════════════════════════════════════════════════════════
# DEPRECATED: Local LLM (optional fallback, not recommended)
# ════════════════════════════════════════════════════════════════
# LOCAL_LLM_ENABLED=false
# LOCAL_LLM_ENDPOINT=http://localhost:8000
# LOCAL_LLM_MODEL=minimaxai_synlogic-7b
